# Copy this file to .env and fill in the values before running tests.
USER_EMAIL=your.email@example.com
USER_PASS=yourpassword
PLAYWRIGHT_BASE_URL=https://stage.app.deepci.com

# --- Status-report emailer (optional) -------------------------------------
# Used by `npm run email:report` / the CI email step. Leave unset to disable
# (the emailer skips quietly when these are not all present).
# For Gmail, MAIL_PASS must be an App Password (account needs 2FA enabled).
MAIL_USER=your.email@gmail.com
MAIL_PASS=your-16-char-app-password
MAIL_TO=recipient1@example.com,recipient2@example.com
# Optional overrides (defaults shown):
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=465
# MAIL_FROM=PMI E2E Bot <your.email@gmail.com>
